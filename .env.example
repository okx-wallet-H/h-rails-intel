# OKX Market API (required for deep market data)
OKX_ACCESS_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_PROJECT_ID=

# API Gateway keys: key:plan:name (comma-separated)
# plan = free | pro | enterprise
GATEWAY_KEYS=gw-dev-key-001:pro:Development

# Server
PORT=3847

# X Layer / GatewayKey contract
XLAYER_RPC_URL=https://xlayerrpc.okx.com
# Mainnet GatewayKey V2 (supports Free → Pro upgrade)
GATEWAY_CONTRACT_ADDRESS=0xc8F599633fCCaDc472c49a307C30BEad918e36Fa
# V1 (legacy): 0x1d27BcB08d77f7f7BC4BF98241c67F4569472BB1

# Optional Redis cache (falls back to in-memory)
REDIS_URL=redis://localhost:6379

# Contract deploy (foundry script only)
DEPLOYER_PRIVATE_KEY=

# Optional: EVM private key for local x402 signing (fallback if onchainos unavailable)
EVM_PRIVATE_KEY=